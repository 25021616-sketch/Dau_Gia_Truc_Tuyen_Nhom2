<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane style="-fx-background-color: #F9FAFB;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Team2_CS2_Auction.Controller.Them_san_pham_controller">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="65.0" spacing="15.0" style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-width: 0 0 1 0;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Button fx:id="Quay_lai_trang_chủ" mnemonicParsing="false" onAction="#handleBackToHome" styleClass="back-button" text="← Trang chủ">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
                <Label style="-fx-font-weight: bold; -fx-text-fill: #1A365D;" text="The Curator">
                    <font><Font size="20.0" /></font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" prefHeight="35.0" prefWidth="120.0" styleClass="btn-primary" text="Admin Panel" />
            </children>
            <padding><Insets left="20.0" right="30.0" /></padding>
        </HBox>

        <ScrollPane fitToWidth="true" styleClass="custom-scroll" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="65.0">
            <content>
                <VBox alignment="TOP_CENTER" spacing="20.0">
                    <children>
                        <VBox maxWidth="900.0" spacing="5.0">
                            <children>
                                <Label style="-fx-text-fill: #111827;" text="Đăng phiên đấu giá mới">
                                    <font><Font name="System Bold" size="26.0" /></font>
                                </Label>
                            </children>
                            <VBox.margin><Insets top="20.0" /></VBox.margin>
                        </VBox>

                        <HBox alignment="TOP_CENTER" maxWidth="950.0" spacing="25.0">
                            <children>
                                <VBox prefWidth="350.0" spacing="15.0" styleClass="card">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Hình ảnh sản phẩm" />
                                        <StackPane prefHeight="200.0" styleClass="image-upload-main">
                                            <children>
                                                <VBox alignment="CENTER" spacing="5.0">
                                                    <children>
                                                        <Label style="-fx-font-size: 30;" text="📸" />
                                                        <Label style="-fx-font-weight: bold;" text="Ảnh chính" textFill="#64748B" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </StackPane>
                                        <HBox spacing="10.0">
                                            <StackPane prefHeight="70.0" styleClass="image-upload-sub" HBox.hgrow="ALWAYS" />
                                            <StackPane prefHeight="70.0" styleClass="image-upload-sub" HBox.hgrow="ALWAYS" />
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox prefWidth="550.0" spacing="12.0" styleClass="card">
                                    <children>
                                        <VBox spacing="5.0">
                                            <Label style="-fx-font-weight: bold;" text="Tên sản phẩm" />
                                            <TextField fx:id="txtTenSanPham" prefHeight="35.0" styleClass="input-field" />
                                        </VBox>

                                        <VBox spacing="5.0">
                                            <Label style="-fx-font-weight: bold;" text="Loại sản phẩm" />
                                            <ComboBox fx:id="loaiSanPhamCombo" maxWidth="Infinity" prefHeight="35.0" promptText="Chọn danh mục..." styleClass="input-field" />
                                        </VBox>

                                        <StackPane>
                                            <children>
                                                <VBox fx:id="groupDoDienTu" managed="false" spacing="10.0" visible="false">
                                                    <children>
                                                        <HBox spacing="10">
                                                            <VBox spacing="5" HBox.hgrow="ALWAYS"><Label style="-fx-font-weight: bold;" text="Hãng sản xuất" /><TextField prefHeight="35.0" styleClass="input-field" /></VBox>
                                                            <VBox spacing="5" HBox.hgrow="ALWAYS"><Label style="-fx-font-weight: bold;" text="Công suất" /><TextField prefHeight="35.0" styleClass="input-field" /></VBox>
                                                        </HBox>
                                                    </children>
                                                </VBox>
                                                <VBox fx:id="groupDongHo" managed="false" spacing="10.0" visible="false">
                                                    <children>
                                                        <HBox spacing="10">
                                                            <VBox spacing="5" HBox.hgrow="ALWAYS"><Label style="-fx-font-weight: bold;" text="Thương hiệu/Hãng" /><TextField prefHeight="35.0" styleClass="input-field" /></VBox>
                                                            <VBox spacing="5" HBox.hgrow="ALWAYS"><Label style="-fx-font-weight: bold;" text="Năm sản xuất" /><TextField prefHeight="35.0" styleClass="input-field" /></VBox>
                                                        </HBox>
                                                    </children>
                                                </VBox>
                                                <VBox fx:id="groupSach" managed="false" spacing="10.0" visible="false">
                                                    <children>
                                                        <HBox spacing="10">
                                                            <VBox spacing="5" HBox.hgrow="ALWAYS"><Label style="-fx-font-weight: bold;" text="Tác giả" /><TextField prefHeight="35.0" styleClass="input-field" /></VBox>
                                                            <VBox spacing="5" HBox.hgrow="ALWAYS"><Label style="-fx-font-weight: bold;" text="Năm sáng tác" /><TextField prefHeight="35.0" styleClass="input-field" /></VBox>
                                                        </HBox>
                                                    </children>
                                                </VBox>
                                                <VBox fx:id="groupBatDongSan" managed="false" spacing="10.0" visible="false">
                                                    <children>
                                                        <HBox spacing="10">
                                                            <VBox spacing="5" HBox.hgrow="ALWAYS"><Label style="-fx-font-weight: bold;" text="Địa chỉ" /><TextField prefHeight="35.0" styleClass="input-field" /></VBox>
                                                            <VBox spacing="5" HBox.hgrow="ALWAYS"><Label style="-fx-font-weight: bold;" text="Diện tích (m2)" /><TextField prefHeight="35.0" styleClass="input-field" /></VBox>
                                                        </HBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </StackPane>

                                        <VBox spacing="5.0">
                                            <Label style="-fx-font-weight: bold;" text="Mô tả chi tiết" />
                                            <TextArea fx:id="txtMoTa" prefHeight="70.0" styleClass="input-field" wrapText="true" />
                                        </VBox>

                                        <HBox spacing="15.0">
                                            <children>
                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                    <Label style="-fx-font-weight: bold; -fx-text-fill: #1A365D;" text="📅 Bắt đầu" />
                                                    <DatePicker fx:id="ngayBatDauPicker" maxWidth="Infinity" />
                                                    <HBox alignment="CENTER_LEFT" spacing="5">
                                                        <TextField fx:id="gioBatDau" prefWidth="50" promptText="HH" />
                                                        <Label text=":" />
                                                        <TextField fx:id="phutBatDau" prefWidth="50" promptText="mm" />
                                                    </HBox>
                                                </VBox>
                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                    <Label style="-fx-font-weight: bold; -fx-text-fill: #9A3412;" text="📅 Kết thúc" />
                                                    <DatePicker fx:id="ngayKetThucPicker" maxWidth="Infinity" />
                                                    <HBox alignment="CENTER_LEFT" spacing="5">
                                                        <TextField fx:id="gioKetThuc" prefWidth="50" promptText="HH" />
                                                        <Label text=":" />
                                                        <TextField fx:id="phutKetThuc" prefWidth="50" promptText="mm" />
                                                    </HBox>
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <HBox spacing="15.0">
                                            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                <Label style="-fx-font-weight: bold;" text="Giá khởi điểm ($)" />
                                                <TextField fx:id="txtGiaKhoiDiem" prefHeight="35.0" styleClass="input-field" />
                                            </VBox>
                                            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                <Label style="-fx-font-weight: bold;" text="Bước giá ($)" />
                                                <TextField fx:id="txtBuocGia" prefHeight="35.0" styleClass="input-field" />
                                            </VBox>
                                        </HBox>

                                        <Button fx:id="Đăng_Phien_Đấu_Giá" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleDangSanPham" prefHeight="45.0" styleClass="btn-primary" text="Đăng phiên đấu giá">
                                            <VBox.margin><Insets top="10" /></VBox.margin>
                                        </Button>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <Region prefHeight="40.0" />
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
