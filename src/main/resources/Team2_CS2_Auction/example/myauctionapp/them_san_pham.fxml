<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane style="-fx-background-color: #F9FAFB;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Team2_CS2_Auction.Controller.Them_san_pham_controller">
    <children>
        <HBox alignment="CENTER_LEFT" prefHeight="65.0" spacing="15.0" style="-fx-background-color: white; -fx-border-color: #E5E7EB; -fx-border-width: 0 0 1 0;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Button fx:id="Quay_lai_trang_chủ" mnemonicParsing="false" onAction="#handleBackToHome" styleClass="back-button" text="← Trang chủ">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Button>
                <Label style="-fx-font-weight: bold; -fx-text-fill: #1A365D;" text="THÔNG TIN PHIÊN ĐẤU GIÁ">
                    <font><Font size="20.0" /></font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
            </children>
            <padding><Insets left="20.0" right="30.0" /></padding>
        </HBox>

        <ScrollPane fitToWidth="true" styleClass="custom-scroll" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="65.0">
            <content>
                <VBox alignment="TOP_CENTER" spacing="20.0">
                    <children>
                        <VBox maxWidth="900.0" spacing="5.0">
                            <children>
                                <Label style="-fx-text-fill: #111827;" text="Đăng phiên đấu giá mới">
                                    <font><Font name="System Bold" size="26.0" /></font>
                                </Label>
                            </children>
                            <VBox.margin><Insets top="20.0" /></VBox.margin>
                        </VBox>

                        <HBox alignment="TOP_CENTER" maxWidth="950.0" spacing="25.0">
                            <children>
                                <VBox prefWidth="350.0" spacing="15.0" styleClass="card">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Hình ảnh sản phẩm" />

                                        <StackPane onMouseClicked="#handleChooseImage" prefHeight="150.0" style="-fx-cursor: hand; -fx-background-color: #f1f5f9; -fx-border-color: #cbd5e1; -fx-border-style: dashed; -fx-border-radius: 5px;" styleClass="image-upload-main">
                                            <children>
                                                <VBox fx:id="vboxPlaceholder" alignment="CENTER" spacing="5.0">
                                                    <children>
                                                        <Label style="-fx-font-size: 30;" text="📸" />
                                                        <Label style="-fx-font-weight: bold;" text="Nhấp để thêm ảnh" textFill="#64748B" />
                                                    </children>
                                                </VBox>
                                                <ImageView fx:id="imgPreview" fitHeight="150.0" fitWidth="330.0" mouseTransparent="true" preserveRatio="true" visible="false" />
                                                <Button fx:id="btnDeleteImage" mnemonicParsing="false" onAction="#handleDeleteImage" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="X" visible="false" StackPane.alignment="TOP_RIGHT">
                                                    <StackPane.margin>
                                                        <Insets right="5.0" top="5.0" />
                                                    </StackPane.margin>
                                                </Button>
                                            </children>
                                        </StackPane>
                                    </children>
                                </VBox>

                                <VBox prefWidth="550.0" spacing="12.0" styleClass="card">
                                    <children>
                                        <VBox spacing="5.0">
                                            <Label style="-fx-font-weight: bold;" text="Tên sản phẩm" />
                                            <TextField fx:id="txtTenSanPham" prefHeight="35.0" styleClass="input-field" />
                                        </VBox>

                                        <VBox spacing="5.0">
                                            <Label style="-fx-font-weight: bold;" text="Danh mục sản phẩm" />
                                            <ComboBox fx:id="loaiSanPhamCombo" maxWidth="Infinity" prefHeight="35.0" promptText="Chọn danh mục..." styleClass="input-field" />
                                        </VBox>

                                        <VBox fx:id="groupDoDienTu" managed="false" spacing="8.0" visible="false">
                                            <children>
                                                <Label style="-fx-font-weight: bold;" text="Thêm thông tin: Đồ điện tử" />
                                                <TextField fx:id="txtHangSX" prefHeight="35.0" promptText="Hãng sản xuất" styleClass="input-field" />
                                                <TextField fx:id="txtCongSuat" prefHeight="35.0" promptText="Công suất / thông số" styleClass="input-field" />
                                            </children>
                                        </VBox>

                                        <VBox fx:id="groupDongHo" managed="false" spacing="8.0" visible="false">
                                            <children>
                                                <Label style="-fx-font-weight: bold;" text="Thêm thông tin: Đồng hồ / Xe / Trang sức" />
                                                <TextField fx:id="txtThuongHieuDH" prefHeight="35.0" promptText="Thương hiệu" styleClass="input-field" />
                                                <TextField fx:id="txtNamSXDH" prefHeight="35.0" promptText="Năm sản xuất / model..." styleClass="input-field" />
                                            </children>
                                        </VBox>

                                        <VBox fx:id="groupSach" managed="false" spacing="8.0" visible="false">
                                            <children>
                                                <Label style="-fx-font-weight: bold;" text="Thêm thông tin: Sách / Nghệ thuật" />
                                                <TextField fx:id="txtTacGia" prefHeight="35.0" promptText="Tác giả / nghệ sĩ" styleClass="input-field" />
                                                <TextField fx:id="txtNamSangTac" prefHeight="35.0" promptText="Năm sáng tác / đời" styleClass="input-field" />
                                            </children>
                                        </VBox>

                                        <VBox fx:id="groupBatDongSan" managed="false" spacing="8.0" visible="false">
                                            <children>
                                                <Label style="-fx-font-weight: bold;" text="Thêm thông tin: Bất động sản" />
                                                <TextField fx:id="txtDiaChiBDS" prefHeight="35.0" promptText="Địa chỉ" styleClass="input-field" />
                                                <TextField fx:id="txtDienTichBDS" prefHeight="35.0" promptText="Diện tích (m²)" styleClass="input-field" />
                                            </children>
                                        </VBox>

                                        <VBox spacing="5.0">
                                            <Label style="-fx-font-weight: bold;" text="Mô tả chi tiết (Tình trạng, cấu hình, hãng...)" />
                                            <TextArea fx:id="txtMoTa" prefHeight="100.0" styleClass="input-field" wrapText="true" />
                                        </VBox>

                                        <HBox spacing="15.0">
                                            <children>
                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                    <Label style="-fx-font-weight: bold; -fx-text-fill: #1A365D;" text="📅 Bắt đầu" />
                                                    <DatePicker fx:id="ngayBatDauPicker" maxWidth="Infinity" />
                                                    <HBox alignment="CENTER_LEFT" spacing="5">
                                                        <TextField fx:id="gioBatDau" prefWidth="50" promptText="HH" />
                                                        <Label text=":" />
                                                        <TextField fx:id="phutBatDau" prefWidth="50" promptText="mm" />
                                                    </HBox>
                                                </VBox>
                                                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                    <Label style="-fx-font-weight: bold; -fx-text-fill: #9A3412;" text="📅 Kết thúc" />
                                                    <DatePicker fx:id="ngayKetThucPicker" maxWidth="Infinity" />
                                                    <HBox alignment="CENTER_LEFT" spacing="5">
                                                        <TextField fx:id="gioKetThuc" prefWidth="50" promptText="HH" />
                                                        <Label text=":" />
                                                        <TextField fx:id="phutKetThuc" prefWidth="50" promptText="mm" />
                                                    </HBox>
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <HBox spacing="15.0">
                                            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                <Label style="-fx-font-weight: bold;" text="Giá khởi điểm ($)" />
                                                <TextField fx:id="txtGiaKhoiDiem" prefHeight="35.0" styleClass="input-field" />
                                            </VBox>
                                            <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                                <Label style="-fx-font-weight: bold;" text="Bước giá ($)" />
                                                <TextField fx:id="txtBuocGia" prefHeight="35.0" styleClass="input-field" />
                                            </VBox>
                                        </HBox>

                                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleDangSanPham" prefHeight="45.0" styleClass="btn-primary" text="Tạo Phiên Đấu Giá">
                                            <VBox.margin><Insets top="10" /></VBox.margin>
                                        </Button>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <Region prefHeight="40.0" />
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</AnchorPane>
