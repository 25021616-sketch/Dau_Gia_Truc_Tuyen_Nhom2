<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="850.0" prefWidth="1300.0" style="-fx-background-color: #F8FAFC; -fx-font-family: 'Segoe UI', system-ui, sans-serif;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Team2_CS2_Auction.Controller.Admin_quan_li_dau_gia_Controller">

    <left>
        <VBox prefWidth="250.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 0 1 0 0;" BorderPane.alignment="CENTER">
            <children>

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <padding>
                        <Insets bottom="30.0" left="24.0" right="24.0" top="30.0" />
                    </padding>
                    <children>
                        <StackPane prefHeight="36.0" prefWidth="36.0" style="-fx-background-color: #1A237E; -fx-background-radius: 8;">
                            <children>
                                <SVGPath content="M12 2L2 22l10-6 10 6L12 2z" fill="WHITE" scaleX="0.5" scaleY="0.5" />
                            </children>
                        </StackPane>
                        <VBox>
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #1A237E;" text="The Curator" />
                                <Label style="-fx-font-size: 9; -fx-text-fill: #718096; -fx-font-weight: bold;" text="AUCTION MANAGEMENT" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="4.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Button fx:id="Dashboard" alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#handleGoToDashboard" style="-fx-background-color: transparent; -fx-text-fill: #4A5568; -fx-cursor: hand; -fx-background-radius: 0; -fx-graphic-text-gap: 12;" text="Bảng điều khiển">
                            <font><Font name="System Bold" size="13.0" /></font>
                            <padding><Insets bottom="12.0" left="24.0" right="24.0" top="12.0" /></padding>
                            <graphic>
                                <SVGPath content="M2 2h6v6H2V2zm10 0h6v6h-6V2zM2 12h6v6H2v-6zm10 0h6v6h-6v-6z" fill="#718096" />
                            </graphic>
                        </Button>

                        <Button fx:id="users" alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#handleGoToUsers" style="-fx-background-color: transparent; -fx-text-fill: #4A5568; -fx-cursor: hand; -fx-background-radius: 0; -fx-graphic-text-gap: 12;" text="Người dùng">
                            <font><Font name="System Bold" size="13.0" /></font>
                            <padding><Insets bottom="12.0" left="24.0" right="24.0" top="12.0" /></padding>
                            <graphic>
                                <SVGPath content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" fill="#718096" />
                            </graphic>
                        </Button>

                        <Button fx:id="inventory" alignment="BASELINE_LEFT" maxWidth="Infinity" style="-fx-background-color: #EBF3FF; -fx-text-fill: #1A237E; -fx-background-radius: 0; -fx-border-color: transparent #1A237E transparent transparent; -fx-border-width: 0 4 0 0; -fx-graphic-text-gap: 12;" text="Kho hàng">
                            <font><Font name="System Bold" size="13.0" /></font>
                            <padding><Insets bottom="12.0" left="24.0" right="24.0" top="12.0" /></padding>
                            <graphic>
                                <SVGPath content="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm-5 14H9v-2h6v2zm3-4H6v-2h12v2zm0-4H6V8h12v2z" fill="#1A237E" />
                            </graphic>
                        </Button>

                        <Button fx:id="history" alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#handleGoToHistory" style="-fx-background-color: transparent; -fx-text-fill: #4A5568; -fx-cursor: hand; -fx-background-radius: 0; -fx-graphic-text-gap: 12;" text="Lịch sử">
                            <font><Font name="System Bold" size="13.0" /></font>
                            <padding><Insets bottom="12.0" left="24.0" right="24.0" top="12.0" /></padding>
                            <graphic>
                                <SVGPath content="M13 3c-4.97 0-9 4.03-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42C12.13 19.13 14.99 20 13 20c5.52 0 10-4.48 10-10S18.52 3 13 3zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z" fill="#718096" />
                            </graphic>
                        </Button>
                    </children>
                </VBox>

                <VBox spacing="4.0">
                    <children>

                        <Button fx:id="btnLogout" alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-text-fill: #E53E3E; -fx-cursor: hand; -fx-graphic-text-gap: 12;" text="Đăng xuất">
                            <font><Font name="System Bold" size="13.0" /></font>
                            <padding><Insets bottom="24.0" left="24.0" right="24.0" top="12.0" /></padding>
                            <graphic>
                                <SVGPath content="M10.09 15.59L11.5 17l5-5-5-5-1.41 1.41L12.67 11H3v2h9.67l-2.58 2.59zM19 3H5c-1.11 0-2 .9-2 2v4h2V5h14v14H5v-4H3v4c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z" fill="#E53E3E" />
                            </graphic>
                        </Button>

                        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #F1F5F9; -fx-background-radius: 12;">
                            <VBox.margin><Insets bottom="20.0" left="16.0" right="16.0" /></VBox.margin>
                            <padding><Insets bottom="10.0" left="12.0" right="12.0" top="10.0" /></padding>
                            <children>
                                <Circle fill="#64748B" radius="16.0" />
                                <VBox>
                                    <children>
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #1E293B;" text="Quản trị viên" />
                                        <Label style="-fx-font-size: 9; -fx-text-fill: #94A3B8; -fx-font-weight: bold;" text="QUYỀN TỐI CAO" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
            <content>
                <VBox spacing="20.0">
                    <padding><Insets bottom="30" left="40" right="40" top="30" /></padding>

                    <HBox alignment="CENTER_LEFT">
                        <VBox spacing="6">
                            <Label style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #0F172A;" text="Phê duyệt Đấu giá" />
                            <Label style="-fx-text-fill: #64748B; -fx-font-size: 14;" text="Danh sách các vật phẩm đang chờ quản trị viên phê duyệt. Hãy kiểm tra kỹ thông tin và giá trước khi xác nhận niêm yết chính thức." />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleAddNewListing" prefHeight="42" style="-fx-background-color: #000B48; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 24; -fx-padding: 0 24; -fx-cursor: hand;" text="+ Niêm yết mới" />
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                        <children>
                            <Button style="-fx-background-color: #EBF3FF; -fx-text-fill: #1A237E; -fx-background-radius: 10; -fx-font-weight: bold; -fx-padding: 8 16; -fx-graphic-text-gap: 8;">
                                <text>Tất cả trạng thái</text>
                                <graphic>
                                    <SVGPath content="M3 11h18v-2H3v2zm0 7h12v-2H3v2zm0-14v2h18V4H3z" fill="#1A237E" scaleX="0.8" scaleY="0.8" />
                                </graphic>
                            </Button>

                            <Region HBox.hgrow="ALWAYS" />
                        </children>
                    </HBox>

                    <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 15; -fx-border-color: #E2E8F0; -fx-border-radius: 16;">
                        <children>
                            <TableView fx:id="tableItems" prefHeight="500" style="-fx-background-color: transparent; -fx-border-width: 0;" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colSTT" prefWidth="50" text="STT" />
                                    <TableColumn fx:id="colID" prefWidth="90" text="ID" />
                                    <TableColumn fx:id="colTen" prefWidth="180" text="Tên vật phẩm" />
                                    <TableColumn fx:id="colChuSoHuu" prefWidth="130" text="Người đăng" />
                                    <TableColumn fx:id="colLoai" prefWidth="100" text="Loại" />
                                    <TableColumn fx:id="colGia" prefWidth="120" text="Giá khởi điểm" />
                                    <TableColumn fx:id="colBuocGia" prefWidth="100" text="Bước giá" />
                                    <TableColumn fx:id="colBatDau" prefWidth="110" text="Bắt đầu" />
                                    <TableColumn fx:id="colKetThuc" prefWidth="110" text="Kết thúc" />
                                    <TableColumn fx:id="colThaoTac" prefWidth="140" text="Thao tác" />
                                </columns>
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                </columnResizePolicy>
                            </TableView>

                            <HBox alignment="CENTER" style="-fx-padding: 20 5 5 5;">
                                <children>
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Region HBox.hgrow="ALWAYS" />
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
                        <children>
                            <HBox alignment="CENTER" prefHeight="35.0" prefWidth="219.0" spacing="12" style="-fx-background-color: #DBEAFE; -fx-background-radius: 24; -fx-padding: 6 16 6 8;">
                                <children>
                                    <HBox alignment="CENTER" prefHeight="22.0" prefWidth="173.0" spacing="6" style="-fx-background-color: #FFFFFF; -fx-background-radius: 20; -fx-padding: 4 12;">
                                        <children>
                                            <Circle fill="#22C55E" radius="4.0" />
                                            <Label prefHeight="14.0" prefWidth="174.0" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #1A237E;" text="HỆ THỐNG TRỰC TUYẾN" />
                                        </children>
                                    </HBox>
                                </children>
                            </HBox>
                        </children>
                    </HBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
