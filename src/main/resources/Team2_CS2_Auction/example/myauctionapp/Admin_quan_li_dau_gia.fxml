<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<BorderPane prefHeight="850.0" prefWidth="1300.0"
            style="-fx-background-color: #F4F7FE; -fx-font-family: 'Segoe UI', sans-serif;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Team2_CS2_Auction.Controller.Admin_quan_li_dau_gia_Controller">

    <left>
        <VBox prefWidth="260.0" style="-fx-background-color: #E2E8F0;">
            <padding><Insets bottom="20" left="20" right="20" top="30" /></padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Circle fill="#1A365D" radius="18" />
                    <VBox>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #1A365D;" text="The Curator" />
                        <Label style="-fx-font-size: 10; -fx-text-fill: #718096;" text="GIÁM SÁT HỆ THỐNG" />
                    </VBox>
                </HBox>
                <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                    <padding><Insets top="40" /></padding>
                    <Button maxWidth="Infinity" onAction="#handleGoToDashboard" prefHeight="45"
                            style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT; -fx-text-fill: #4A5568; -fx-font-size: 14; -fx-cursor: hand;" text="Bảng điều khiển" />
                    <Button maxWidth="Infinity" onAction="#handleGoToUsers" prefHeight="45"
                            style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT; -fx-text-fill: #4A5568; -fx-font-size: 14; -fx-cursor: hand;" text="Người dùng" />
                    <Button maxWidth="Infinity" prefHeight="45"
                            style="-fx-background-color: white; -fx-background-radius: 12; -fx-alignment: CENTER_LEFT; -fx-font-weight: bold; -fx-font-size: 14; -fx-text-fill: #1A365D;" text="Kho hàng" />
                    <Button maxWidth="Infinity" onAction="#handleGoToHistory" prefHeight="45"
                            style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT; -fx-text-fill: #4A5568; -fx-font-size: 14; -fx-cursor: hand;" text="Lịch sử" />
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
                <VBox spacing="25.0">
                    <padding><Insets bottom="30" left="40" right="40" top="30" /></padding>

                    <HBox alignment="CENTER_LEFT">
                        <VBox>
                            <Label style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #1A365D;" text="Phê duyệt Đấu giá" />
                            <Label style="-fx-text-fill: #718096; -fx-font-size: 14;" text="Danh sách các vật phẩm đang chờ quản trị viên phê duyệt." />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleAddNewListing" prefHeight="40"
                                style="-fx-background-color: #1A365D; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 0 20;" text="+ Niêm yết mới" />
                    </HBox>

                    <VBox style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 20;">
                        <TableView fx:id="tableItems" prefHeight="600" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colSTT" text="STT" />
                                <TableColumn fx:id="colID" text="ID" />
                                <TableColumn fx:id="colTen" text="Tên vật phẩm" />
                                <TableColumn fx:id="colChuSoHuu" text="Người đăng" />
                                <TableColumn fx:id="colLoai" text="Loại" />
                                <TableColumn fx:id="colGia" text="Giá khởi điểm" />
                                <TableColumn fx:id="colBuocGia" text="Bước giá" />
                                <TableColumn fx:id="colBatDau" text="Bắt đầu" />
                                <TableColumn fx:id="colKetThuc" text="Kết thúc" />
                                <TableColumn fx:id="colThaoTac" text="Thao tác" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>