<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="850.0" prefWidth="1300.0"
            style="-fx-background-color: #F4F7FE; -fx-font-family: 'Segoe UI', system-ui, sans-serif;"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Team2_CS2_Auction.Controller.Admin_quan_li_lich_su_Controller">

    <left>
        <VBox prefWidth="260.0" style="-fx-background-color: #E2E8F0;">
            <padding><Insets bottom="20" left="20" right="20" top="30" /></padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Circle fill="#1A365D" radius="18" />
                    <VBox>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #1A365D;" text="The Curator" />
                        <Label style="-fx-font-size: 10; -fx-text-fill: #718096; -fx-text-transform: uppercase;" text="Giám sát hệ thống" />
                    </VBox>
                </HBox>
                <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                    <padding><Insets top="40" /></padding>
                    <Button fx:id="Dashboard" maxWidth="Infinity" onAction="#handleGoToDashboard" prefHeight="45" styleClass="menu-btn" text="Bảng điều khiển" />
                    <Button fx:id="users" maxWidth="Infinity" onAction="#handleGoToUsers" prefHeight="45" styleClass="menu-btn" text="Người dùng" />
                    <Button fx:id="inventory" maxWidth="Infinity" onAction="#handleGoToInventory" prefHeight="45" styleClass="menu-btn" text="Kho hàng" />
                    <Button fx:id="history" maxWidth="Infinity" prefHeight="45"
                            style="-fx-background-color: white; -fx-background-radius: 12; -fx-alignment: CENTER_LEFT; -fx-font-weight: bold; -fx-font-size: 14; -fx-padding: 0 0 0 20; -fx-text-fill: #1A365D; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);" text="Lịch sử" />
                </VBox>
                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 12;">
                    <Circle fill="#2D3748" radius="15" />
                    <VBox>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 12;" text="Quản trị viên" />
                        <Label style="-fx-font-size: 10; -fx-text-fill: #A0AEC0;" text="QUYỀN TỐI CAO" />
                    </VBox>
                </HBox>
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
            <content>
                <VBox spacing="25.0">
                    <padding><Insets bottom="30" left="40" right="40" top="30" /></padding>

                    <HBox alignment="CENTER_LEFT">
                        <VBox>
                            <Label style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1A365D;" text="Lịch sử &amp; Báo cáo" />
                            <Label style="-fx-text-fill: #718096; -fx-font-size: 14;" text="Bản ghi chi tiết các phiên đấu giá đã kết thúc." />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox spacing="10">
                            <Button style="-fx-background-color: white; -fx-text-fill: #1A365D; -fx-background-radius: 10; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-padding: 8 15;" text="Xuất CSV" />
                            <Button style="-fx-background-color: #1A365D; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 8 15;" text="In báo cáo" />
                        </HBox>
                    </HBox>

                    <HBox spacing="20.0">
                        <VBox prefWidth="400.0" spacing="10" style="-fx-background-color: #1A365D; -fx-background-radius: 20; -fx-padding: 25;">
                            <Label style="-fx-text-fill: #CBD5E0; -fx-font-size: 12;" text="TỔNG DOANH THU ĐÃ CHỐT" />
                            <Label style="-fx-text-fill: white; -fx-font-size: 32; -fx-font-weight: bold;" text="\$2,840,000" />
                        </VBox>
                        <VBox alignment="CENTER_LEFT" prefWidth="250.0" spacing="5" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 10, 0, 0, 5);">
                            <Label style="-fx-font-size: 24; -fx-font-weight: bold;" text="1,402" />
                            <Label style="-fx-text-fill: #718096; -fx-font-size: 12;" text="Phiên thành công" />
                        </VBox>
                    </HBox>

                    <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 15, 0, 0, 5);">
                        <HBox alignment="CENTER_LEFT">
                            <Label style="-fx-font-weight: bold; -fx-font-size: 18; -fx-text-fill: #2D3748;" text="Nhật ký giao dịch" />
                            <Region HBox.hgrow="ALWAYS" />
                            <TextField promptText="Tìm theo tên hoặc ID..." style="-fx-background-color: #F4F7FE; -fx-background-radius: 8; -fx-pref-width: 250;" />
                        </HBox>

                        <TableView fx:id="historyTable" prefHeight="450" styleClass="modern-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colSTT" maxWidth="50.0" text="STT" />
                                <TableColumn fx:id="colID" maxWidth="70.0" text="ID" />
                                <TableColumn fx:id="colTenSanPham" minWidth="220.0" text="Tên sản phẩm" />
                                <TableColumn fx:id="colNguoiThang" minWidth="180.0" text="Người thắng" />
                                <TableColumn fx:id="colGiaChot" minWidth="120.0" text="Giá chốt ($)" />
                                <TableColumn fx:id="colThoiDiem" minWidth="180.0" text="Thời điểm thắng" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                        <HBox alignment="CENTER_RIGHT" spacing="10">
                            <Pagination maxPageIndicatorCount="3" pageCount="10" />
                        </HBox>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>