<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Team2_CS2_Auction.Controller.Phien_Dau_Gia_Controller">
    <content>
        <HBox prefHeight="850.0" prefWidth="1150.0" style="-fx-background-color: #F8F8FA;">
            <children>
                <VBox prefWidth="650.0" spacing="25.0" style="-fx-background-color: #F3F3F7;" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets bottom="40.0" left="50.0" right="50.0" top="30.0" />
                    </padding>
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #1A237E;" text="NHÀ GIÁM ĐỊNH • CHI TIẾT PHIÊN ĐẤU GIÁ" />

                        <VBox alignment="CENTER" style="-fx-background-color: #FFFFFF; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);" VBox.vgrow="ALWAYS">
                            <children>
                                <ImageView fx:id="productImage" fitHeight="450.0" fitWidth="450.0" pickOnBounds="true" preserveRatio="true" />
                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <Label fx:id="lblTenSanPham" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #212121;" text="Tên sản phẩm" />
                            <Label fx:id="lblMoTa" style="-fx-font-size: 16px; -fx-text-fill: #757575;" text="Mô tả sẽ hiển thị tại đây." wrapText="true" />
                        </VBox>

                        <HBox spacing="15.0">
                            <Label style="-fx-background-color: #E8EAF6; -fx-text-fill: #3F51B5; -fx-padding: 8 15; -fx-background-radius: 8; -fx-font-weight: bold;" text="TÌNH TRẠNG: TỐT" />
                            <Label style="-fx-background-color: #E0E0E0; -fx-text-fill: #616161; -fx-padding: 8 15; -fx-background-radius: 8; -fx-font-weight: bold;" text="XÁC THỰC 100%" />
                        </HBox>
                    </children>
                </VBox>

                <VBox prefWidth="500.0" spacing="25.0" style="-fx-background-color: #FFFFFF;" HBox.hgrow="NEVER">
                    <padding>
                        <Insets bottom="40.0" left="40.0" right="40.0" top="30.0" />
                    </padding>
                    <children>
                        <HBox alignment="TOP_RIGHT">
                            <Button onAction="#handleClose" style="-fx-background-color: #EEEEEE; -fx-background-radius: 50; -fx-cursor: hand; -fx-min-width: 35; -fx-min-height: 35;" text="✕" />
                        </HBox>

                        <VBox spacing="5.0">
                            <Label style="-fx-text-fill: #9E9E9E; -fx-font-weight: bold;" text="GIÁ HIỆN TẠI ($)" />
                            <Label fx:id="currentBidLabel" style="-fx-font-size: 48px; -fx-font-weight: 900; -fx-text-fill: #1A237E;" text="0" />
                            <Label fx:id="lblThoiGian" style="-fx-text-fill: #D32F2F; -fx-font-weight: bold;" text="⏱ Đang nạp..." />
                        </VBox>

                        <Separator />

                        <VBox spacing="20.0" style="-fx-background-color: #F8F9FB; -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: #E8EAF6; -fx-border-radius: 12;">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1A237E;" text="CÀI ĐẶT BƯỚC NHẢY (n)" />
                                <HBox spacing="15">
                                    <children>
                                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                                            <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #757575;" text="SỐ BƯỚC NHẢY (n)" />
                                            <Spinner fx:id="stepSpinner" editable="true" maxWidth="Infinity" prefHeight="45.0" />
                                        </VBox>
                                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                                            <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #757575;" text="MỨC TĂNG / BƯỚC" />
                                            <ComboBox fx:id="bidStepCombo" maxWidth="Infinity" prefHeight="45.0" />
                                        </VBox>
                                    </children>
                                </HBox>

                                <VBox alignment="CENTER_LEFT" spacing="5" style="-fx-background-color: #E8F5E9; -fx-padding: 15; -fx-background-radius: 8;">
                                    <children>
                                        <Label style="-fx-font-size: 11px; -fx-text-fill: #2E7D32; -fx-font-weight: bold;" text="TỔNG GIÁ SAU KHI ĐẶT (MỚI)" />
                                        <Label fx:id="targetPriceLabel" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;" text="0" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <Button maxWidth="Infinity" onAction="#handlePlaceBid" prefHeight="65.0" style="-fx-background-color: #1A237E; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18px; -fx-background-radius: 12; -fx-cursor: hand;" text="XÁC NHẬN ĐẶT GIÁ" />

                        <Separator />
                        <VBox spacing="10">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #424242;" text="ĐẤU THẦU TỰ ĐỘNG" />
                            <TextField fx:id="autoLimitField" prefHeight="45.0" promptText="Giới hạn tối đa ($)" />
                            <Button maxWidth="Infinity" onAction="#handleActivateAutoBid" prefHeight="45.0" style="-fx-border-color: #1A237E; -fx-text-fill: #1A237E; -fx-font-weight: bold;" text="KÍCH HOẠT ỦY QUYỀN" />
                        </VBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </content>
</ScrollPane>