<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Team2_CS2_Auction.Controller.Phien_Dau_Gia_Controller">
    <content>
        <VBox prefWidth="1250.0" spacing="20.0" style="-fx-background-color: #F8F8FA; -fx-padding: 25;">
            <children>

                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 18px; -fx-text-fill: #1A237E;" text="CHI TIẾT PHIÊN ĐẤU GIÁ" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleClose" style="-fx-background-color: #EEEEEE; -fx-background-radius: 50; -fx-cursor: hand; -fx-min-width: 35; -fx-min-height: 35;" text="✕" />
                    </children>
                </HBox>

                <HBox spacing="25.0" VBox.vgrow="ALWAYS">
                    <children>

                        <VBox maxWidth="750.0" spacing="25.0" HBox.hgrow="ALWAYS">
                            <children>

                                <VBox spacing="20.0" style="-fx-background-color: #FFFFFF; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 5);">
                                    <children>
                                        <HBox alignment="TOP_LEFT" spacing="30.0">
                                            <children>
                                                <VBox alignment="CENTER" style="-fx-background-color: #F3F3F7; -fx-background-radius: 15; -fx-padding: 15; -fx-border-color: #E0E0E0; -fx-border-radius: 15;">
                                                    <children>
                                                        <ImageView fx:id="productImage" fitHeight="280.0" fitWidth="280.0" pickOnBounds="true" preserveRatio="true" />
                                                    </children>
                                                </VBox>

                                                <VBox spacing="15.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label fx:id="lblTenSanPham" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #212121;" text="Tên sản phẩm" wrapText="true" />
                                                        <Label fx:id="lblMoTa" style="-fx-font-size: 15px; -fx-text-fill: #757575; -fx-line-spacing: 5;" text="Mô tả chi tiết sản phẩm sẽ được hiển thị tại đây để người dùng nắm rõ thông tin trước khi đặt giá." wrapText="true" />

                                                        <HBox spacing="15.0" style="-fx-padding: 10 0 0 0;" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <VBox spacing="10.0" style="-fx-background-color: #FFFFFF; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 5);" VBox.vgrow="ALWAYS">
                                    <children>
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #1A237E;" text="BIỂU ĐỒ LỊCH SỬ ĐẶT GIÁ" />
                                        <LineChart fx:id="bidHistoryChart" animated="false" legendVisible="false" style="-fx-padding: 10 0 0 0;" VBox.vgrow="ALWAYS">
                                            <xAxis>
                                                <CategoryAxis animated="false" label="Thời gian" tickLabelRotation="-90" />
                                            </xAxis>
                                            <yAxis>
                                                <NumberAxis animated="false" label="Giá ($)" />
                                            </yAxis>
                                        </LineChart>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <VBox maxWidth="500.0" minWidth="400.0" spacing="25.0" style="-fx-background-color: #FFFFFF; -fx-padding: 30; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 5);" HBox.hgrow="ALWAYS">
                            <children>

                                <VBox spacing="15.0">
                                    <children>
                                        <VBox spacing="5.0">
                                            <Label style="-fx-text-fill: #9E9E9E; -fx-font-weight: bold; -fx-font-size: 14px;" text="GIÁ HIỆN TẠI ($)" />
                                            <Label fx:id="currentBidLabel" style="-fx-font-size: 56px; -fx-font-weight: 900; -fx-text-fill: #1A237E;" text="0" />
                                        </VBox>

                                        <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-background-color: #FFEBEE; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #FFCDD2; -fx-border-radius: 10;">
                                            <children>
                                                <Label fx:id="lblThoiGian" style="-fx-text-fill: #D32F2F; -fx-font-weight: bold; -fx-font-size: 18px;" text="⏱ Đang nạp thời gian..." />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>

                                <Separator />

                                <VBox spacing="20.0">
                                    <Label style="-fx-font-weight: bold; -fx-font-size: 15px; -fx-text-fill: #1A237E;" text="BẢNG ĐIỀU KHIỂN ĐẶT GIÁ" />

                                    <HBox spacing="15.0">
                                        <children>
                                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                                <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #757575;" text="SỐ BƯỚC NHẢY (n)" />
                                                <Spinner fx:id="stepSpinner" editable="true" maxWidth="Infinity" prefHeight="45.0" />
                                            </VBox>
                                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                                <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #757575;" text="MỨC TĂNG / BƯỚC" />
                                                <TextField fx:id="bidStepField" prefHeight="45.0" promptText="VD: 50" style="-fx-background-radius: 5;" />
                                            </VBox>
                                        </children>
                                    </HBox>

                                    <VBox spacing="8" style="-fx-background-color: #E8F5E9; -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: #C8E6C9; -fx-border-radius: 12;">
                                        <children>
                                            <Label style="-fx-font-size: 12px; -fx-text-fill: #2E7D32; -fx-font-weight: bold;" text="TỔNG GIÁ DỰ KIẾN (MỚI)" />
                                            <Label fx:id="targetPriceLabel" style="-fx-font-size: 38px; -fx-font-weight: bold; -fx-text-fill: #2E7D32;" text="0" />
                                        </children>
                                    </VBox>

                                    <Button maxWidth="Infinity" onAction="#handlePlaceBid" prefHeight="60.0" style="-fx-background-color: #1A237E; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18px; -fx-background-radius: 10; -fx-cursor: hand;" text="XÁC NHẬN ĐẶT GIÁ" />
                                </VBox>

                                <Separator />

                                <VBox spacing="15.0">
                                    <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #424242;" text="ỦY QUYỀN ĐẤU THẦU TỰ ĐỘNG" />
                                    <HBox spacing="15.0">
                                        <children>
                                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                                <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #757575;" text="SỐ LẦN BƯỚC GIÁ" />
                                                <TextField fx:id="autoStepsCountField" prefHeight="45.0" promptText="VD: 1" style="-fx-background-radius: 5;" />
                                            </VBox>
                                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                                <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #757575;" text="GIỚI HẠN TỐI ĐA ($)" />
                                                <TextField fx:id="autoLimitField" prefHeight="45.0" promptText="Ví dụ: 5000" style="-fx-background-radius: 5;" />
                                            </VBox>
                                        </children>
                                    </HBox>
                                    <Button fx:id="btnActivateAutoBid" maxWidth="Infinity" onAction="#handleActivateAutoBid" prefHeight="45.0" style="-fx-border-color: #1A237E; -fx-border-radius: 5; -fx-background-color: transparent; -fx-text-fill: #1A237E; -fx-font-weight: bold; -fx-cursor: hand;" text="KÍCH HOẠT" />
                                </VBox>

                                <!-- ===== QUẢN LÝ SẢN PHẨM (chỉ hiện với chủ sở hữu) ===== -->
                                <VBox fx:id="ownerActionsBox" spacing="12.0" visible="false" managed="false">
                                    <Separator />
                                    <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #B71C1C;" text="⚙ QUẢN LÝ SẢN PHẨM CỦA BẠN" />
                                    <HBox spacing="12.0">
                                        <children>
                                            <Button fx:id="btnXoa" maxWidth="Infinity" onAction="#handleXoa"
                                                    prefHeight="50.0" prefWidth="160.0"
                                                    style="-fx-background-color: #D32F2F; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-background-radius: 10; -fx-cursor: hand;"
                                                    text="🗑 XÓA" HBox.hgrow="ALWAYS" />
                                            <Button fx:id="btnDangLai" maxWidth="Infinity" onAction="#handleDangLai"
                                                    prefHeight="50.0" prefWidth="160.0"
                                                    style="-fx-background-color: #F57F17; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-background-radius: 10; -fx-cursor: hand;"
                                                    text="🔄 ĐĂNG LẠI" HBox.hgrow="ALWAYS" />
                                        </children>
                                    </HBox>
                                    <Label style="-fx-text-fill: #757575; -fx-font-size: 12px; -fx-wrap-text: true;"
                                           text="⚠ Xóa: hủy phiên vĩnh viễn. Đăng lại: hủy và đăng phiên mới với thời gian bạn chọn."
                                           wrapText="true" />
                                </VBox>

                            </children>
                        </VBox>

                    </children>
                </HBox>

            </children>
        </VBox>
    </content>
</ScrollPane>
