<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane style="-fx-background-color: #f1f5f9;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Team2_CS2_Auction.Controller.Dang_nhap_Controller">
    <children>
        <HBox alignment="CENTER" maxHeight="560.0" maxWidth="820.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 30, 0, 0, 15);">
            <children>

                <VBox alignment="CENTER" minHeight="500.0" minWidth="350.0" prefHeight="547.0" prefWidth="350.0" spacing="25.0" style="-fx-background-color: #20335e; -fx-background-radius: 20 0 0 20;">
                    <children>
                        <Label text="Trường Đại học Công nghệ - ĐHQGHN" textFill="WHITE">
                            <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                        <VBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Label text="Hệ Thống Đấu Giá" textFill="WHITE">
                                    <font><Font name="System Bold" size="28.0" /></font>
                                </Label>
                                <Label text="Trực Tuyến" textFill="WHITE">
                                    <font><Font name="System Bold" size="28.0" /></font>
                                </Label>
                            </children>
                        </VBox>
                        <VBox spacing="10.0" style="-fx-padding: 0 0 0 35;" />
                    </children>
                </VBox>

                <VBox alignment="TOP_CENTER" minHeight="500.0" minWidth="450.0" spacing="20.0">
                    <padding>
                        <Insets bottom="40.0" left="50.0" right="50.0" top="30.0" />
                    </padding>
                    <children>

                        <VBox spacing="20.0" VBox.vgrow="ALWAYS">
                            <children>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #20335e;" text="Chào mừng trở lại">
                                            <font><Font size="24.0" /></font>
                                        </Label>
                                        <Label text="Vui lòng đăng nhập để tiếp tục." textFill="#64748b" />
                                    </children>
                                </VBox>

                                <VBox spacing="10.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Tên đăng nhập" textFill="#20335e" />
                                        <TextField fx:id="Ten_dang_nhap" prefHeight="45.0" promptText="Nhập tài khoản" style="-fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10;" />
                                    </children>
                                </VBox>

                                <VBox spacing="10.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Mật khẩu" textFill="#20335e" />
                                        <StackPane alignment="CENTER_RIGHT">
                                            <children>
                                                <PasswordField fx:id="Mat_khau" prefHeight="45.0" promptText="••••••••" style="-fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-padding: 0 40 0 10;" />
                                                <TextField fx:id="txtMatKhauShow" visible="false" managed="false" prefHeight="45.0" promptText="••••••••" style="-fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-padding: 0 40 0 10;" />
                                                <Button fx:id="btnTogglePassword" onAction="#handleTogglePassword" text="👁" style="-fx-background-color: transparent; -fx-text-fill: #757575; -fx-cursor: hand; -fx-padding: 0 15 0 0;" StackPane.alignment="CENTER_RIGHT" />
                                            </children>
                                        </StackPane>
                                    </children>
                                </VBox>

                                <CheckBox fx:id="Dang_nhap_Admin" mnemonicParsing="false" text="Đăng nhập Admin" textFill="#20335e" />

                                <Label fx:id="lblMessage" style="-fx-font-weight: bold; -fx-font-size: 13px;" textFill="#d32f2f" wrapText="true" />

                                <Button fx:id="btnLogin" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleLogin" prefHeight="50.0" style="-fx-background-color: #20335e; -fx-background-radius: 10; -fx-cursor: hand;" text="Đăng Nhập" textFill="WHITE">
                                    <font><Font name="System Bold" size="15.0" /></font>
                                </Button>

                                <HBox alignment="CENTER" spacing="5.0">
                                    <children>
                                        <Label text="Chưa có tài khoản?" textFill="#64748b" />
                                        <Hyperlink onAction="#handleSwitchToRegister" style="-fx-padding: 0;" text="Đăng ký ngay.">
                                            <font><Font name="System Bold Italic" size="12.0" /></font>
                                        </Hyperlink>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</StackPane>
