<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="900.0" prefWidth="1300.0" style="-fx-background-color: #f1f5f9;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Team2_CS2_Auction.Controller.Dang_nhap_Controller">
    <children>
        <HBox alignment="CENTER" fillHeight="false" maxHeight="-Infinity" maxWidth="-Infinity" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 30, 0, 0, 15);">
            <children>

                <VBox alignment="CENTER" minHeight="500.0" minWidth="350.0" spacing="25.0" style="-fx-background-color: #20335e; -fx-background-radius: 20 0 0 20;">
                    <children>
                        <Label text="Đại học Công Nghệ - ĐHQGHN" textFill="WHITE">
                            <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                        <VBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Label text="Hệ Thống Đấu Giá" textFill="WHITE">
                                    <font><Font name="System Bold" size="28.0" /></font>
                                </Label>
                                <Label text="Trực Tuyến" textFill="WHITE">
                                    <font><Font name="System Bold" size="28.0" /></font>
                                </Label>
                            </children>
                        </VBox>
                        <VBox spacing="10.0" style="-fx-padding: 0 0 0 35;">
                            <children>
                                <Label text="&quot;Nền tảng minh bạch – Kết nối giá trị thực.&quot;" textFill="#cbd5e1" wrapText="true">
                                    <font><Font name="System Italic" size="12.0" /></font>
                                </Label>
                                <Label text="&quot;Định chuẩn giá trị – Nâng tầm giao dịch.&quot;" textFill="#cbd5e1" wrapText="true">
                                    <font><Font name="System Italic" size="12.0" /></font>
                                </Label>
                                <Label text="&quot;Đấu giá an toàn, mua bán dễ dàng.&quot;" textFill="#cbd5e1" wrapText="true">
                                    <font><Font name="System Italic" size="12.0" /></font>
                                </Label>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox alignment="TOP_CENTER" minHeight="500.0" minWidth="450.0" spacing="20.0">
                    <padding>
                        <Insets bottom="40.0" left="50.0" right="50.0" top="30.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" prefWidth="200.0">
                            <children>
                                <Button fx:id="btnBack" mnemonicParsing="false" style="-fx-background-color: #20335e; -fx-background-radius: 50; -fx-cursor: hand;" text="←" textFill="WHITE" />
                            </children>
                        </HBox>

                        <VBox spacing="20.0" VBox.vgrow="ALWAYS">
                            <children>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #20335e;" text="Chào mừng trở lại">
                                            <font><Font size="24.0" /></font>
                                        </Label>
                                        <Label text="Vui lòng đăng nhập để tiếp tục." textFill="#64748b" />
                                    </children>
                                </VBox>

                                <VBox spacing="10.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Tên đăng nhập" textFill="#20335e" />
                                        <TextField fx:id="Ten_dang_nhap" prefHeight="45.0" promptText="Nhập tài khoản" style="-fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10;" />
                                    </children>
                                </VBox>

                                <VBox spacing="10.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Mật khẩu" textFill="#20335e" />
                                        <PasswordField fx:id="Mat_khau" prefHeight="45.0" promptText="••••••••" style="-fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10;" />
                                    </children>
                                </VBox>

                                <CheckBox fx:id="Dang_nhap_Admin" mnemonicParsing="false" text="Đăng nhập Admin" textFill="#20335e" />

                                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleLogin" prefHeight="50.0" style="-fx-background-color: #20335e; -fx-background-radius: 10; -fx-cursor: hand;" text="Đăng Nhập" textFill="WHITE">
                                    <font><Font name="System Bold" size="15.0" /></font>
                                </Button>

                                <HBox alignment="CENTER" spacing="5.0">
                                    <children>
                                        <Label text="Chưa có tài khoản?" textFill="#64748b" />
                                        <Hyperlink onAction="#handleSwitchToRegister" style="-fx-padding: 0;" text="Đăng ký ngay.">
                                            <font><Font name="System Bold Italic" size="12.0" /></font>
                                        </Hyperlink>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</StackPane>