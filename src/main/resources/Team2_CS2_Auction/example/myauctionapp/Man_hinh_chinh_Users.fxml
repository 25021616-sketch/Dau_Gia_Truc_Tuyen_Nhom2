<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane prefHeight="900.0" prefWidth="1300.0" style="-fx-background-color: #FFFFFF;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Team2_CS2_Auction.Controller.Man_hinh_chinh_Users_Controller">
    <children>
        <BorderPane prefHeight="900.0" prefWidth="1300.0">
            <top>
                <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="30.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E9ECEF; -fx-border-width: 0 0 1 0;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="15.0" left="30.0" right="30.0" top="15.0" />
            </padding>
            <children>
                <Label text="HỆ THỐNG ĐẤU GIÁ TRỰC TUYẾN" textFill="#1A237E">
                    <font>
                        <Font name="System Bold Italic" size="24.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER_LEFT" prefHeight="39.0" prefWidth="363.0" spacing="10.0" style="-fx-background-color: #E8EAF6; -fx-background-radius: 20; -fx-border-color: #C5CAE9; -fx-border-width: 1; -fx-border-radius: 20;">
                    <padding>
                        <Insets bottom="6.0" left="15.0" right="15.0" top="6.0" />
                    </padding>
                    <children>
                        <Label prefHeight="20.0" prefWidth="22.0" text="👤" textFill="#1A237E">
                            <font><Font size="14.0" /></font>
                        </Label>
                        <Label fx:id="lblUsername" prefHeight="19.0" prefWidth="66.0" text="User" textFill="#1A237E">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Label>
                        <Label text="|" textFill="#9FA8DA" />
                        <Label prefHeight="19.0" prefWidth="45.0" text="Số dư:" textFill="#5C6BC0">
                            <font><Font size="13.0" /></font>
                        </Label>
                        <Label fx:id="lblBalance" text="0.00 $" textFill="#2E7D32">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                    </children>
                </HBox>
                <!-- Bell button + badge -->
                <StackPane onMouseClicked="#handleToggleNotifications">
                    <Button fx:id="btnChuong" mnemonicParsing="false"
                            style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 18px;"
                            text="🔔" />
                    <Label fx:id="lblBadgeChuong" alignment="CENTER" style="-fx-background-color: #D32F2F; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 1 4;" text="0" visible="false" managed="false">
                        <StackPane.margin><Insets top="0.0" left="15.0" /></StackPane.margin>
                    </Label>
                </StackPane>
                <Button mnemonicParsing="false" onAction="#handleGoToDangNhap" style="-fx-background-color: #b10303; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;" text="ĐĂNG XUẤT">
                    <font><Font name="System Bold" size="12.0" /></font>
                    <padding><Insets bottom="8.0" left="20.0" right="20.0" top="8.0" /></padding>
                </Button>
            </children>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="240.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E9ECEF; -fx-border-width: 0 1 0 0;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="30.0" left="20.0" right="20.0" top="40.0" />
            </padding>
            <children>
                <Label prefHeight="50.0" text="MENU" textFill="#1A237E">
                    <font><Font name="System Bold" size="18.0" /></font>
                    <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                </Label>

                <VBox spacing="10.0">
                    <children>
                        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" style="-fx-background-color: #1A237E; -fx-text-fill: white; -fx-background-radius: 20;" text="CÁC PHIÊN ĐẤU GIÁ">
                            <font><Font name="System Bold" size="11.0" /></font>
                            <padding><Insets bottom="12.0" left="15.0" right="15.0" top="12.0" /></padding>
                        </Button>
                        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#handleOpenNapTienPopup" style="-fx-background-color: transparent; -fx-text-fill: #495057; -fx-cursor: hand;" text="NẠP TIỀN">
                            <font><Font name="System Bold" size="11.0" /></font>
                            <padding><Insets bottom="12.0" left="15.0" right="15.0" top="12.0" /></padding>
                        </Button>
                        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#handleGoToLichSu" style="-fx-background-color: transparent; -fx-text-fill: #495057; -fx-cursor: hand;" text="PHIÊN ĐÃ THAM GIA">
                            <font><Font name="System Bold" size="11.0" /></font>
                            <padding><Insets bottom="12.0" left="15.0" right="15.0" top="12.0" /></padding>
                        </Button>
                        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#handleGoToSanPhamCuaToi" style="-fx-background-color: transparent; -fx-text-fill: #495057; -fx-cursor: hand;" text="PHIÊN CỦA TÔI">
                            <font><Font name="System Bold" size="11.0" /></font>
                            <padding><Insets bottom="12.0" left="15.0" right="15.0" top="12.0" /></padding>
                        </Button>
                        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#handleGoTothemsanpham" style="-fx-background-color: transparent; -fx-text-fill: #495057; -fx-cursor: hand;" text="TẠO PHIÊN ĐẤU GIÁ">
                            <font><Font name="System Bold" size="11.0" /></font>
                            <padding><Insets bottom="12.0" left="15.0" right="15.0" top="12.0" /></padding>
                        </Button>
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #FFFFFF;" BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="40.0">
                    <padding><Insets bottom="50.0" left="60.0" right="60.0" top="40.0" /></padding>
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Sàn Đấu Giá Trực Tuyến" textFill="#1A237E">
                                    <font><Font name="Times New Roman Bold" size="36.0" /></font>
                                </Label>
                                <Label text="Danh sách các phiên đấu giá" textFill="#6C757D">
                                    <font><Font size="15.0" /></font>
                                </Label>
                            </children>
                        </VBox>

                        <FlowPane fx:id="pnlItems" hgap="30.0" prefWrapLength="1000.0" vgap="30.0" />

                        <VBox spacing="20.0">
                            <VBox.margin><Insets top="50.0" /></VBox.margin>
                            <children>
                                <Region prefHeight="1.0" style="-fx-background-color: #E9ECEF;" />
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label text="PHÁT TRIỂN BỞI" textFill="#1A237E">
                                                    <font><Font name="System Bold Italic" size="14.0" /></font>
                                                </Label>
                                                <Label text="UET - VNU _ K70 - CS2 - TEAM 2" textFill="#ADB5BD">
                                                    <font><Font size="9.0" /></font>
                                                </Label>
                                            </children>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label text="© 2026 K70I - CS2 _ TEAM 2" textFill="#ADB5BD">
                                            <font><Font size="10.0" /></font>
                                        </Label>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>

<!-- Notification popup overlay centered on screen -->
<VBox fx:id="notificationPopup" visible="false" managed="false"
      maxWidth="450.0" maxHeight="500.0"
      style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 12; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.18), 20, 0, 0, 8); -fx-padding: 0;"
      StackPane.alignment="CENTER">
    <children>
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #1A237E; -fx-background-radius: 12 12 0 0; -fx-padding: 14 20;">
            <children>
                <Label text="🔔 Thông báo" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px;" HBox.hgrow="ALWAYS" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleClearNotifications" style="-fx-background-color: transparent; -fx-text-fill: #90CAF9; -fx-cursor: hand; -fx-font-size: 11px;" text="Xóa tất cả" mnemonicParsing="false" />
                <Button onAction="#handleCloseNotifications" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-font-size: 14px;" text="✕" mnemonicParsing="false" />
            </children>
        </HBox>
        <ScrollPane fitToWidth="true" maxHeight="400.0" style="-fx-background: white; -fx-background-color: white;">
            <content>
                <VBox fx:id="notificationList" spacing="0.0" />
            </content>
        </ScrollPane>
        <Label fx:id="lblNoNotifications" alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill: #9E9E9E; -fx-font-size: 13px; -fx-padding: 20;" text="Không có thông báo nào" visible="true" />
    </children>
</VBox>
    </children>
</StackPane>
