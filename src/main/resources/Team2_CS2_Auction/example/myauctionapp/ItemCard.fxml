                                <Font name="System Bold" size="10.0" />
                            </font>
                        </Label>

                        <Label fx:id="lblTenSP" minHeight="50.0" prefWidth="240.0" text="Đối xứng thanh tao II - Tác phẩm sơn dầu" textFill="#1a237e" wrapText="true">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>

                        <VBox spacing="2.0" style="-fx-background-color: #FFF9F9; -fx-padding: 10; -fx-background-radius: 8;">
                            <children>
                                <Label fx:id="lblTieuDeThoiGian" text="Thời gian còn lại:" textFill="#616161">
