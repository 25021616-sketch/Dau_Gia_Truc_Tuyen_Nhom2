                        <Label fx:id="lblBadgeTrangThai" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-padding: 5 10; -fx-background-radius: 5;" text="ĐANG DIỄN RA" StackPane.alignment="TOP_LEFT">
                            <font>
                                <Font name="System Bold" size="10.0" />
                            </font>
                            <StackPane.margin>
                                <Insets left="15.0" top="15.0" />
