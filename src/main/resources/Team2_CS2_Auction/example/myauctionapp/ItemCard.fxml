                <Button fx:id="btnDatGia" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleDatGia" prefHeight="45.0" style="-fx-background-color: #1a237e; -fx-background-radius: 0 0 15 15; -fx-cursor: hand;" text="XEM CHI TIẾT" textFill="WHITE">
                    <font>
