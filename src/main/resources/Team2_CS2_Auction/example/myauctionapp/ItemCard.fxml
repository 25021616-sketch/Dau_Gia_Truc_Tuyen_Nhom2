<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="420.0" prefWidth="280.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-border-color: #E0E0E0; -fx-border-width: 1;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Team2_CS2_Auction.Controller.Item_Card_Controller">
    <children>
        <VBox alignment="TOP_CENTER" layoutX="1.0" layoutY="1.0" prefWidth="278.0" spacing="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <StackPane prefHeight="180.0" style="-fx-background-color: #F8F9FA; -fx-background-radius: 15 15 0 0;">
