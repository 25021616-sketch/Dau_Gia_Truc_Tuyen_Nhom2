<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane prefHeight="900.0" prefWidth="1300.0" style="-fx-background-color: #f1f5f9;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Team2_CS2_Auction.Controller.Dang_ki_tai_khoan_Controller">
    <children>
        <HBox alignment="CENTER" maxHeight="520.0" maxWidth="720.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 30, 0, 0, 15);">
            <children>

                <VBox alignment="CENTER" minWidth="320.0" prefWidth="320.0" spacing="20.0" style="-fx-background-color: #20335e; -fx-background-radius: 20 0 0 20;">
                    <children>
                        <Label text="Trường Đại học Công nghệ - ĐHQGHN" textFill="WHITE">
                            <font><Font name="System Bold" size="11.0" /></font>
                        </Label>
                        <VBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label text="Hệ Thống Đấu Giá" textFill="WHITE">
                                    <font><Font name="System Bold" size="26.0" /></font>
                                </Label>
                                <Label text="Trực Tuyến" textFill="WHITE">
                                    <font><Font name="System Bold" size="26.0" /></font>
                                </Label>
                            </children>
                        </VBox>
                        <VBox spacing="8.0" style="-fx-padding: 0 0 0 35;" />
                    </children>
                </VBox>

                <VBox alignment="TOP_CENTER" minWidth="400.0" prefWidth="400.0" spacing="0.0">
                    <padding>
                        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
                    </padding>
                    <children>
                        <VBox spacing="15.0" VBox.vgrow="ALWAYS">
                            <children>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #20335e;" text="Tạo tài khoản">
                                            <font><Font size="22.0" /></font>
                                        </Label>
                                        <Label text="Bắt đầu hành trình của bạn ngay bây giờ." textFill="#64748b" />
                                    </children>
                                </VBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Tên đăng nhập" textFill="#20335e" />
                                        <TextField fx:id="Ten_dang_ki" prefHeight="40.0" promptText="Nhập tài khoản mới" style="-fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10;" />
                                    </children>
                                </VBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Số điện thoại" textFill="#20335e" />
                                        <TextField fx:id="Sdt_dang_ki" prefHeight="40.0" promptText="0xxx xxx xxx" style="-fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10;" />
                                    </children>
                                </VBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Mật khẩu" textFill="#20335e" />
                                        <StackPane alignment="CENTER_RIGHT">
                                            <children>
                                                <PasswordField fx:id="Dat_mat_khau" prefHeight="40.0" promptText="••••••••" style="-fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-padding: 0 40 0 10;" />
                                                <TextField fx:id="txtMatKhauShow" visible="false" managed="false" prefHeight="40.0" promptText="••••••••" style="-fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-padding: 0 40 0 10;" />
                                                <Button fx:id="btnTogglePassword" onAction="#handleTogglePassword" text="👁" style="-fx-background-color: transparent; -fx-text-fill: #757575; -fx-cursor: hand; -fx-padding: 0 15 0 0;" StackPane.alignment="CENTER_RIGHT" />
                                            </children>
                                        </StackPane>
                                    </children>
                                </VBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Nhập lại mật khẩu" textFill="#20335e" />
                                        <StackPane alignment="CENTER_RIGHT">
                                            <children>
                                                <PasswordField fx:id="Nhap_lai_mat_khau" prefHeight="40.0" promptText="••••••••" style="-fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-padding: 0 40 0 10;" />
                                                <TextField fx:id="txtConfirmMatKhauShow" visible="false" managed="false" prefHeight="40.0" promptText="••••••••" style="-fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-padding: 0 40 0 10;" />
                                                <Button fx:id="btnToggleConfirmPassword" onAction="#handleToggleConfirmPassword" text="👁" style="-fx-background-color: transparent; -fx-text-fill: #757575; -fx-cursor: hand; -fx-padding: 0 15 0 0;" StackPane.alignment="CENTER_RIGHT" />
                                            </children>
                                        </StackPane>
                                    </children>
                                </VBox>

                                <Label fx:id="lblMessage" style="-fx-font-weight: bold; -fx-font-size: 13px;" textFill="#d32f2f" wrapText="true" />

                                <Button fx:id="Dang_ky" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleRegister" prefHeight="48.0" style="-fx-background-color: #20335e; -fx-background-radius: 10; -fx-cursor: hand;" text="Đăng Ký" textFill="WHITE">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                    <VBox.margin>
                                        <Insets top="10.0" />
                                    </VBox.margin>
                                </Button>

                                <HBox alignment="CENTER" spacing="5.0">
                                    <children>
                                        <Label text="Đã có tài khoản?" textFill="#64748b" />
                                        <Hyperlink onAction="#handleSwitchToLogin" style="-fx-padding: 0;" text="Đăng nhập ngay.">
                                            <font><Font name="System Bold Italic" size="12.0" /></font>
                                        </Hyperlink>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</StackPane>
