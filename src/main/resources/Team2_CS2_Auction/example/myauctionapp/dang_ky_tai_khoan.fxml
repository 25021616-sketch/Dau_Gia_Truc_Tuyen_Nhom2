<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="900.0" prefWidth="1300.0" style="-fx-background-color: #f1f5f9;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Team2_CS2_Auction.Controller.Dang_ki_tai_khoan_Controller">
    <children>
        <HBox alignment="CENTER" maxHeight="520.0" maxWidth="720.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 30, 0, 0, 15);">
            <children>

                <VBox alignment="CENTER" minWidth="320.0" prefWidth="320.0" spacing="20.0" style="-fx-background-color: #20335e; -fx-background-radius: 20 0 0 20;">
                    <children>
                        <Label text="Đại học Công Nghệ - ĐHQGHN" textFill="WHITE">
                            <font><Font name="System Bold" size="11.0" /></font>
                        </Label>
                        <VBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label text="Hệ Thống Đấu Giá" textFill="WHITE">
                                    <font><Font name="System Bold" size="26.0" /></font>
                                </Label>
                                <Label text="Trực Tuyến" textFill="WHITE">
                                    <font><Font name="System Bold" size="26.0" /></font>
                                </Label>
                            </children>
                        </VBox>
                        <VBox spacing="8.0" style="-fx-padding: 0 0 0 35;">
                            <children>
                                <Label text="&quot;Nền tảng minh bạch – Kết nối giá trị thực.&quot;" textFill="#cbd5e1" wrapText="true">
                                    <font><Font name="System Italic" size="10.0" /></font>
                                </Label>
                                <Label text="&quot;Định chuẩn giá trị – Nâng tầm giao dịch.&quot;" textFill="#cbd5e1" wrapText="true">
                                    <font><Font name="System Italic" size="10.0" /></font>
                                </Label>
                                <Label text="&quot;Đấu giá an toàn, mua bán dễ dàng.&quot;" textFill="#cbd5e1" wrapText="true">
                                    <font><Font name="System Italic" size="10.0" /></font>
                                </Label>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox alignment="TOP_CENTER" minWidth="400.0" prefWidth="400.0" spacing="0.0">
                    <padding>
                        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
                    </padding>
                    <children>
                        <VBox spacing="15.0" VBox.vgrow="ALWAYS">
                            <children>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold; -fx-text-fill: #20335e;" text="Tạo tài khoản">
                                            <font><Font size="22.0" /></font>
                                        </Label>
                                        <Label text="Bắt đầu hành trình của bạn ngay bây giờ." textFill="#64748b" />
                                    </children>
                                </VBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Tên đăng nhập" textFill="#20335e" />
                                        <TextField fx:id="Ten_dang_ki" prefHeight="40.0" promptText="Nhập tài khoản mới" style="-fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10;" />
                                    </children>
                                </VBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Số điện thoại" textFill="#20335e" />
                                        <TextField fx:id="Sdt_dang_ki" prefHeight="40.0" promptText="0xxx xxx xxx" style="-fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10;" />
                                    </children>
                                </VBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Mật khẩu" textFill="#20335e" />
                                        <PasswordField fx:id="Dat_mat_khau" prefHeight="40.0" promptText="••••••••" style="-fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10;" />
                                    </children>
                                </VBox>

                                <VBox spacing="5.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Nhập lại mật khẩu" textFill="#20335e" />
                                        <PasswordField fx:id="Nhap_lai_mat_khau" prefHeight="40.0" promptText="••••••••" style="-fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10;" />
                                    </children>
                                </VBox>

                                <Button fx:id="Dang_ky" maxWidth="Infinity" mnemonicParsing="false" prefHeight="48.0" style="-fx-background-color: #20335e; -fx-background-radius: 10; -fx-cursor: hand;" text="Đăng Ký" textFill="WHITE">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                    <VBox.margin>
                                        <Insets top="10.0" />
                                    </VBox.margin>
                                </Button>

                                <HBox alignment="CENTER" spacing="5.0">
                                    <children>
                                        <Label text="Đã có tài khoản?" textFill="#64748b" />
                                        <Hyperlink onAction="#handleSwitchToLogin" style="-fx-padding: 0;" text="Đăng nhập ngay.">
                                            <font><Font name="System Bold Italic" size="12.0" /></font>
                                        </Hyperlink>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</StackPane>