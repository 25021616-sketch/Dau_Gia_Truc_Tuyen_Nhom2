<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="850.0" prefWidth="1300.0"
            style="-fx-background-color: #F4F7FE; -fx-font-family: 'Segoe UI', sans-serif;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Team2_CS2_Auction.Controller.Admin_quan_li_User_Controller">

    <left>
        <VBox prefWidth="240.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E9ECEF; -fx-border-width: 0 1 0 0;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="30.0" left="20.0" right="20.0" top="30.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Circle fill="#1A237E" radius="18" />
                    <VBox>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #1A237E;" text="The Curator" />
                        <Label style="-fx-font-size: 10; -fx-text-fill: #6C757D; -fx-text-transform: uppercase;" text="Giám sát hệ thống" />
                    </VBox>
                </HBox>

                <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                    <padding><Insets top="40" /></padding>
                    <Button alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#handleGoToDashboard"
                            style="-fx-background-color: transparent; -fx-text-fill: #495057; -fx-cursor: hand;" text="BẢNG ĐIỀU KHIỂN">
                        <font><Font name="System Bold" size="11.0" /></font>
                        <padding><Insets bottom="12.0" left="15.0" right="15.0" top="12.0" /></padding>
                    </Button>
                    
                    <Button alignment="BASELINE_LEFT" maxWidth="Infinity"
                            style="-fx-background-color: #1A237E; -fx-text-fill: white; -fx-background-radius: 20;" text="NGƯỜI DÙNG">
                        <font><Font name="System Bold" size="11.0" /></font>
                        <padding><Insets bottom="12.0" left="15.0" right="15.0" top="12.0" /></padding>
                    </Button>
                    
                    <Button alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#handleGoToInventory"
                            style="-fx-background-color: transparent; -fx-text-fill: #495057; -fx-cursor: hand;" text="KHO HÀNG">
                        <font><Font name="System Bold" size="11.0" /></font>
                        <padding><Insets bottom="12.0" left="15.0" right="15.0" top="12.0" /></padding>
                    </Button>
                    
                    <Button alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#handleGoToHistory"
                            style="-fx-background-color: transparent; -fx-text-fill: #495057; -fx-cursor: hand;" text="LỊCH SỬ">
                        <font><Font name="System Bold" size="11.0" /></font>
                        <padding><Insets bottom="12.0" left="15.0" right="15.0" top="12.0" /></padding>
                    </Button>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #F8F9FA; -fx-background-radius: 12; -fx-padding: 12;">
                    <Circle fill="#6C757D" radius="15" />
                    <VBox>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 12; -fx-text-fill: #495057;" text="Quản trị viên" />
                        <Label style="-fx-font-size: 10; -fx-text-fill: #ADB5BD;" text="QUYỀN TỐI CAO" />
                    </VBox>
                </HBox>
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="25.0">
            <padding><Insets bottom="30" left="40" right="40" top="30" /></padding>

            <HBox alignment="CENTER_LEFT">
                <VBox>
                    <Label style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1A365D;" text="Quản lý Người dùng" />
                    <Label style="-fx-text-fill: #718096; -fx-font-size: 14;" text="Danh sách tài khoản và quyền hạn." />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="15">
                    <Button onAction="#handleBanUser" prefHeight="40" prefWidth="130"
                            style="-fx-background-color: #E53E3E; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" text="Khóa tài khoản" />
                    <Button onAction="#handleUnbanUser" prefHeight="40" prefWidth="130"
                            style="-fx-background-color: #38A169; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" text="Mở khóa" />
                </HBox>
            </HBox>

            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 15, 0, 0, 5);" VBox.vgrow="ALWAYS">
                <children>
                    <TableView fx:id="userTable" prefHeight="550" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colSTT" maxWidth="60.0" minWidth="50.0" text="STT" />
                            <TableColumn fx:id="colID" maxWidth="100.0" minWidth="70.0" text="ID" />
                            <TableColumn fx:id="colTen" minWidth="200.0" text="Tên người dùng" />
                            <TableColumn fx:id="colTaiSan" minWidth="150.0" text="Tài sản (Số dư)" />
                            <TableColumn fx:id="colNgayDangKy" minWidth="180.0" text="Ngày đăng ký" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </children>
            </VBox>
        </VBox>
    </center>
</BorderPane>