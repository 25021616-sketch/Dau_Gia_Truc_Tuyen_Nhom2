<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="900.0" prefWidth="1300.0" style="-fx-background-color: #FFFFFF;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Team2_CS2_Auction.Controller.San_pham_cua_toi_Controller">

    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="30.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E9ECEF; -fx-border-width: 0 0 1 0;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="15.0" left="30.0" right="30.0" top="15.0" />
            </padding>
            <children>
                <Label text="HỆ THỐNG ĐẤU GIÁ TRỰC TUYẾN" textFill="#1A237E">
                    <font>
                        <Font name="System Bold Italic" size="24.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER_LEFT" prefWidth="350.0" style="-fx-background-color: #F8F9FA; -fx-background-radius: 5;">
                    <padding>
                        <Insets bottom="8.0" left="15.0" right="15.0" top="8.0" />
                    </padding>
                    <children>
                        <Label text="🔍" textFill="#ADB5BD" />
                        <TextField promptText="Chức năng này đang phát triển!" style="-fx-background-color: transparent; -fx-prompt-text-fill: #ADB5BD;" HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #E8EAF6; -fx-background-radius: 20; -fx-border-color: #C5CAE9; -fx-border-width: 1; -fx-border-radius: 20;">
                    <padding>
                        <Insets bottom="6.0" left="15.0" right="15.0" top="6.0" />
                    </padding>
                    <children>
                        <Label text="👤" textFill="#1A237E">
                            <font><Font size="14.0" /></font>
                        </Label>
                        <Label fx:id="lblUsername" text="User" textFill="#1A237E">
                            <font><Font name="System Bold" size="13.0" /></font>
                        </Label>
                        <Label text="|" textFill="#9FA8DA" />
                        <Label text="Số dư:" textFill="#5C6BC0">
                            <font><Font size="13.0" /></font>
                        </Label>
                        <Label fx:id="lblBalance" text="0.00 $" textFill="#2E7D32">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                    </children>
                </HBox>
                <Label style="-fx-cursor: hand;" text="🔔" textFill="#1A237E">
                    <font><Font size="18.0" /></font>
                </Label>
                <Button mnemonicParsing="false" onAction="#handleGoToDangNhap" style="-fx-background-color: #b10303; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;" text="ĐĂNG XUẤT">
                    <font><Font name="System Bold" size="12.0" /></font>
                    <padding><Insets bottom="8.0" left="20.0" right="20.0" top="8.0" /></padding>
                </Button>
            </children>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="240.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E9ECEF; -fx-border-width: 0 1 0 0;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="30.0" left="20.0" right="20.0" top="40.0" />
            </padding>
            <children>
                <Label prefHeight="50.0" text="MENU" textFill="#1A237E">
                    <font><Font name="System Bold" size="18.0" /></font>
                    <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                </Label>

                <VBox spacing="10.0">
                    <children>
                        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#handleQuayLaiTrangChu" style="-fx-background-color: transparent; -fx-text-fill: #495057; -fx-cursor: hand;" text="CÁC PHIÊN ĐẤU GIÁ">
                            <font><Font name="System Bold" size="11.0" /></font>
                            <padding><Insets bottom="12.0" left="15.0" right="15.0" top="12.0" /></padding>
                        </Button>
                        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#handleOpenNapTienPopup" style="-fx-background-color: transparent; -fx-text-fill: #495057; -fx-cursor: hand;" text="NẠP TIỀN">
                            <font><Font name="System Bold" size="11.0" /></font>
                            <padding><Insets bottom="12.0" left="15.0" right="15.0" top="12.0" /></padding>
                        </Button>
                        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#handleGoToLichSu" style="-fx-background-color: transparent; -fx-text-fill: #495057; -fx-cursor: hand;" text="PHIÊN ĐÃ THAM GIA">
                            <font><Font name="System Bold" size="11.0" /></font>
                            <padding><Insets bottom="12.0" left="15.0" right="15.0" top="12.0" /></padding>
                        </Button>
                        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" style="-fx-background-color: #1A237E; -fx-text-fill: white; -fx-background-radius: 20;" text="PHIÊN CỦA TÔI">
                            <font><Font name="System Bold" size="11.0" /></font>
                            <padding><Insets bottom="12.0" left="15.0" right="15.0" top="12.0" /></padding>
                        </Button>
                        <Button alignment="BASELINE_LEFT" maxWidth="Infinity" onAction="#handleGoTothemsanpham" style="-fx-background-color: transparent; -fx-text-fill: #495057; -fx-cursor: hand;" text="TẠO PHIÊN ĐẤU GIÁ">
                            <font><Font name="System Bold" size="11.0" /></font>
                            <padding><Insets bottom="12.0" left="15.0" right="15.0" top="12.0" /></padding>
                        </Button>
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #FFFFFF;" BorderPane.alignment="CENTER">
            <content>
                <VBox spacing="40.0">
                    <padding><Insets bottom="50.0" left="60.0" right="60.0" top="40.0" /></padding>
                    <children>

                        <HBox alignment="BOTTOM_LEFT">
                            <children>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Sản phẩm của tôi" textFill="#1A237E">
                                            <font><Font name="Times New Roman Bold" size="36.0" /></font>
                                        </Label>
                                        <Label text="Quản lý các lô hàng bạn đã đăng bán hoặc sở hữu." textFill="#6C757D">
                                            <font><Font size="15.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS" />
                                <Button onAction="#handleGoTothemsanpham" style="-fx-background-color: #28A745; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand;" text="+ TẠO MỚI">
                                    <font><Font name="System Bold" size="12.0" /></font>
                                    <padding><Insets bottom="10.0" left="20.0" right="20.0" top="10.0" /></padding>
                                </Button>
                            </children>
                        </HBox>

                        <FlowPane fx:id="pnlMyItems" hgap="30.0" vgap="30.0" />

                        <VBox spacing="20.0">
                            <children>
                                <Region prefHeight="1.0" style="-fx-background-color: #E9ECEF;" />
                                <HBox alignment="BOTTOM_LEFT">
                                    <children>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label text="PHÁT TRIỂN BỞI" textFill="#1A237E">
                                                    <font><Font name="System Bold Italic" size="18.0" /></font>
                                                </Label>
                                                <Label text="UET - VNU _ K70 - CS2 - TEAM 2" textFill="#ADB5BD">
                                                    <font><Font size="9.0" /></font>
                                                </Label>
                                            </children>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label text="© 2026 K70I - CS2 _ TEAM 2" textFill="#ADB5BD">
                                            <font><Font size="10.0" /></font>
                                        </Label>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>