                                    <children>
                                        <Pane prefHeight="400.0" style="-fx-background-color: #243B63; -fx-background-radius: 4 4 0 0;" />
                                        <VBox spacing="15.0">
                                            <padding><Insets bottom="30.0" left="30.0" right="30.0" top="30.0" /></padding>
                                            <children>
                                                <Label text="LÔ CAO CẤP #042" textFill="#1A237E">
                                                    <font><Font name="System Bold" size="10.0" /></font>
                                                </Label>
                                                <Label text="Bản dạ khúc Sapphire" textFill="#1A237E">
                                                    <font><Font name="Times New Roman Bold" size="28.0" /></font>
                                                </Label>
                                                <HBox alignment="BOTTOM_LEFT">
                                                    <children>
                                                        <Label maxWidth="450.0" text="Một ví dụ xuất sắc về chủ nghĩa biểu hiện trừu tượng giữa thế kỷ." textFill="#6C757D" wrapText="true" />
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <VBox alignment="CENTER_RIGHT">
                                                            <Label text="GIÁ HIỆN TẠI" textFill="#ADB5BD"><font><Font size="10.0" /></font></Label>
                                                            <Label text="\$1,240,000" textFill="#1A237E"><font><Font name="Times New Roman Bold" size="32.0" /></font></Label>
                                                        </VBox>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </center>
