<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import java.net.URL?>

<BorderPane prefHeight="850.0" prefWidth="1300.0"
            style="-fx-background-color: #F4F7FE; -fx-font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Team2_CS2_Auction.Controller.Trang_chu_Admin_Controller">

    <top>
        <HBox alignment="CENTER_RIGHT" prefHeight="50.0" spacing="15.0" style="-fx-background-color: transparent;">
            <padding>
                <Insets right="20.0" top="10.0" />
            </padding>
            <children>
                <Button fx:id="btnLogout" onAction="#handleLogout"
                        style="-fx-background-color: #E53E3E; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 5 15;"
                        text="Đăng xuất" />
            </children>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="260.0" style="-fx-background-color: #E2E8F0;">
            <padding><Insets bottom="20" left="20" right="20" top="10" /></padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Circle fill="#1A365D" radius="18" />
                    <VBox>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #1A365D;" text="The Curator" />
                        <Label style="-fx-font-size: 10; -fx-text-fill: #718096; -fx-text-transform: uppercase;" text="Giám sát hệ thống" />
                    </VBox>
                </HBox>

                <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                    <padding><Insets top="40" /></padding>

                    <Button fx:id="Dashboard" maxWidth="Infinity" prefHeight="45"
                            style="-fx-background-color: white; -fx-background-radius: 12; -fx-alignment: CENTER_LEFT; -fx-font-weight: bold; -fx-font-size: 14; -fx-padding: 0 0 0 20; -fx-text-fill: #1A365D; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);"
                            text="Bảng điều khiển" />

                    <Button fx:id="users" maxWidth="Infinity" prefHeight="45" onAction="#handleGoToUser"
                            style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-font-size: 14; -fx-padding: 0 0 0 20; -fx-text-fill: #4A5568;"
                            text="Người dùng" />

                    <Button fx:id="inventory" maxWidth="Infinity" prefHeight="45" onAction="#handleGoToInventory"
                            style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-font-size: 14; -fx-padding: 0 0 0 20; -fx-text-fill: #4A5568;"
                            text="Kho hàng" />

                    <Button fx:id="history" maxWidth="Infinity" prefHeight="45" onAction="#handleGoToHistory"
                            style="-fx-background-color: transparent; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-font-size: 14; -fx-padding: 0 0 0 20; -fx-text-fill: #4A5568;"
                            text="Lịch sử" />
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 12;">
                    <Circle fill="#2D3748" radius="15" />
                    <VBox>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 12;" text="Quản trị viên" />
                        <Label style="-fx-font-size: 10; -fx-text-fill: #A0AEC0;" text="QUYỀN TỐI CAO" />
                    </VBox>
                </HBox>
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
            <VBox spacing="25.0">
                <padding><Insets bottom="30" left="40" right="40" top="10" /></padding>

                <HBox alignment="CENTER_LEFT">
                    <Label style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1A365D;" text="Hệ thống Quản trị Đấu giá" />
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER" spacing="25.0">
                        <Label style="-fx-font-weight: bold; -fx-border-color: transparent transparent #1A365D transparent; -fx-border-width: 0 0 3 0; -fx-padding: 0 0 5 0;" text="Tổng quan" />
                        <Label style="-fx-text-fill: #718096; -fx-font-size: 14; -fx-cursor: hand;" text="Báo cáo" />
                        <Label style="-fx-text-fill: #718096; -fx-font-size: 14; -fx-cursor: hand;" text="Cài đặt" />
                        <Circle fill="#4A5568" radius="18.0" style="-fx-cursor: hand;" />
                    </HBox>
                </HBox>

                <HBox spacing="20.0">
                    <VBox prefWidth="480.0" spacing="12.0" style="-fx-background-color: #1A365D; -fx-background-radius: 20; -fx-padding: 30; -fx-effect: dropshadow(three-pass-box, rgba(26,54,93,0.2), 15, 0, 0, 10);">
                        <Label style="-fx-text-fill: #CBD5E0; -fx-font-size: 11; -fx-font-weight: bold; -fx-text-transform: uppercase;" text="Tổng giao dịch (30 ngày)" />
                        <Label style="-fx-text-fill: white; -fx-font-size: 38; -fx-font-weight: bold;" text="\$1,284,500" />
                        <Label style="-fx-text-fill: #68D391; -fx-font-weight: bold; -fx-font-size: 13;" text="↗ +12.5% so với kỳ trước" />
                    </VBox>

                    <VBox alignment="CENTER_LEFT" prefWidth="240.0" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: transparent transparent transparent #ED8936; -fx-border-width: 0 0 0 6; -fx-padding: 20 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 10, 0, 0, 5);">
                        <Label style="-fx-font-size: 32; -fx-font-weight: bold;" text="432" />
                        <Label style="-fx-text-fill: #718096; -fx-font-weight: bold; -fx-font-size: 12;" text="Lượt thầu đang chạy" />
                    </VBox>

                    <VBox alignment="CENTER_LEFT" prefWidth="240.0" spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: transparent transparent transparent #667EEA; -fx-border-width: 0 0 0 6; -fx-padding: 20 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 10, 0, 0, 5);">
                        <Label style="-fx-font-size: 32; -fx-font-weight: bold;" text="12,840" />
                        <Label style="-fx-text-fill: #718096; -fx-font-weight: bold; -fx-font-size: 12;" text="Tổng người dùng" />
                    </VBox>
                </HBox>

                <VBox spacing="15.0">
                    <HBox alignment="BOTTOM_LEFT">
                        <Label style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2D3748;" text="Vật phẩm Đấu giá Trực tiếp" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Hyperlink onAction="#handleGoToInventory" style="-fx-text-fill: #3182CE; -fx-underline: false; -fx-font-weight: bold;" text="Xem tất cả kho hàng" />
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 10, 0, 0, 5);">
                        <Rectangle arcHeight="15" arcWidth="15" fill="#CBD5E0" height="75.0" width="75.0" />
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label style="-fx-text-fill: #B7791F; -fx-font-size: 10; -fx-font-weight: bold; -fx-text-transform: uppercase;" text="Bộ sưu tập đồng hồ" />
                            <Label style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #1A365D;" text="1964 Patek Philippe Calatrava" />
                            <Label style="-fx-text-fill: #718096; -fx-font-size: 13;" text="Tình trạng tuyệt vời, bao gồm hộp và giấy tờ gốc." />
                        </VBox>
                        <VBox alignment="CENTER_RIGHT" spacing="5">
                            <Label style="-fx-font-size: 11; -fx-text-fill: #A0AEC0; -fx-font-weight: bold;" text="GIÁ THẦU HIỆN TẠI" />
                            <Label style="-fx-font-weight: bold; -fx-font-size: 20; -fx-text-fill: #1A365D;" text="\$42,500" />
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>

    <right>
        <VBox prefWidth="350.0" spacing="20.0" style="-fx-background-color: #F4F7FE;">
            <padding><Insets bottom="30" left="10" right="30" top="10" /></padding>

            <VBox spacing="18.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 15, 0, 0, 5);">
                <Label style="-fx-font-weight: bold; -fx-font-size: 15; -fx-text-fill: #1A365D;" text="Hoạt động Đấu thầu" />
                <HBox alignment="BOTTOM_CENTER" prefHeight="160.0" spacing="10.0">
                    <Rectangle arcHeight="8" arcWidth="8" fill="#E2E8F0" height="60" width="18" />
                    <Rectangle arcHeight="8" arcWidth="8" fill="#E2E8F0" height="95" width="18" />
                    <Rectangle arcHeight="8" arcWidth="8" fill="#E2E8F0" height="50" width="18" />
                    <Rectangle arcHeight="8" arcWidth="8" fill="#4A5568" height="120" width="18" />
                    <Rectangle arcHeight="8" arcWidth="8" fill="#1A365D" height="145" width="18" />
                    <Rectangle arcHeight="8" arcWidth="8" fill="#2B6CB0" height="110" width="18" />
                </HBox>
                <Separator />
                <HBox alignment="CENTER">
                    <Label style="-fx-font-size: 12; -fx-text-fill: #718096;" text="Số lượt thầu mỗi giờ:" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #1A365D;" text="124" />
                </HBox>
            </VBox>

            <VBox spacing="18.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 15, 0, 0, 5);">
                <Label style="-fx-font-weight: bold; -fx-font-size: 15; -fx-text-fill: #1A365D;" text="Hoạt động Trực tiếp" />
                <VBox spacing="15">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Circle fill="#FED7D7" radius="16" />
                        <VBox>
                            <Label style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #2D3748;" text="Người dùng @johndoe trả giá $45k" />
                            <Label style="-fx-font-size: 11; -fx-text-fill: #A0AEC0;" text="2 phút trước" />
                        </VBox>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Circle fill="#E2E8F0" radius="16" />
                        <VBox>
                            <Label style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #2D3748;" text="Cộng tác viên mới xác minh" />
                            <Label style="-fx-font-size: 11; -fx-text-fill: #A0AEC0;" text="15 phút trước" />
                        </VBox>
                    </HBox>
                </VBox>
                <Button maxWidth="Infinity" onAction="#handleGoToHistory" style="-fx-background-color: transparent; -fx-text-fill: #3182CE; -fx-font-weight: bold; -fx-font-size: 12; -fx-cursor: hand;" text="Xem nhật ký hoạt động →" />
            </VBox>
        </VBox>
    </right>
</BorderPane>